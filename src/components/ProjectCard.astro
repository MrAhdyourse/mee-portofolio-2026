---
import type { Project } from '../data/projects';
import { ExternalLink, Github } from 'lucide-astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const tagSlugs = project.tags
  .map((t) => t.toLowerCase().replace(/\s+/g, '-'))
  .join(' ');
---

<article
  class="project-card group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white/90 shadow-sm ring-1 ring-slate-950/5 transition-all duration-500 hover:-translate-y-2 hover:border-teal-500/40 hover:shadow-2xl hover:ring-teal-500/10 dark:border-slate-700/90 dark:bg-slate-900/60 dark:ring-white/5 dark:hover:border-teal-400/35"
  data-tags={tagSlugs}
  role="listitem"
>
  <!-- Gradient overlay on hover -->
  <div class="project-gradient"></div>
  
  <!-- Content -->
  <div class="relative z-10 flex flex-1 flex-col p-6">
    <div class="mb-3 flex items-start justify-between gap-3">
      <h3 class="text-lg font-semibold tracking-tight text-slate-900 transition-colors group-hover:text-teal-600 dark:text-slate-50 dark:group-hover:text-teal-400">
        {project.title}
      </h3>
      <div class="project-icon">
        <span class="text-xl">🚀</span>
      </div>
    </div>
    
    <p class="flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
      {project.description}
    </p>
    
    <ul class="mt-4 flex flex-wrap gap-2" aria-label="Tag teknologi">
      {
        project.tags.map((tag) => (
          <li>
            <span class="project-tag">
              {tag}
            </span>
          </li>
        ))
      }
    </ul>
    
    <div class="mt-5 flex flex-wrap gap-3">
      {
        project.href && project.href !== '#' && (
          <a
            class="project-link project-link-primary"
            href={project.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            <ExternalLink size={16} />
            <span>Live Demo</span>
          </a>
        )
      }
      {
        project.repo && (
          <a
            class="project-link project-link-secondary"
            href={project.repo}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Github size={16} />
            <span>GitHub</span>
          </a>
        )
      }
    </div>
  </div>
  
  <!-- Shine effect -->
  <div class="project-shine"></div>
</article>
