---
import { Star, GitFork, ExternalLink, Github } from 'lucide-astro';

interface Props {
  repo: {
    name: string;
    description: string;
    url: string;
    homepage?: string;
    stars: number;
    forks: number;
    language?: string;
    topics: string[];
    updated: string;
  };
  index: number;
}

const { repo, index } = Astro.props;

const languageColors: Record<string, string> = {
  JavaScript: '#f1e05a',
  TypeScript: '#3178c6',
  Python: '#3572A5',
  Java: '#b07219',
  HTML: '#e34c26',
  CSS: '#563d7c',
  PHP: '#4F5D95',
  Ruby: '#701516',
  Go: '#00ADD8',
  Rust: '#dea584',
  C: '#555555',
  'C++': '#f34b7d',
  'C#': '#178600',
  Shell: '#89e051',
  Vue: '#41b883',
  Astro: '#ff5a03',
};

const langColor = repo.language ? languageColors[repo.language] || '#8b949e' : '#8b949e';
---

<article class="github-repo-card" style={`animation-delay: ${index * 0.05}s`}>
  <div class="repo-header">
    <div class="flex items-start justify-between gap-3">
      <div class="flex-1 min-w-0">
        <h3 class="repo-title">
          <Github size={18} class="inline-block" />
          {repo.name}
        </h3>
        <p class="repo-description">{repo.description}</p>
      </div>
    </div>
  </div>

  <div class="repo-body">
    {repo.topics.length > 0 && (
      <div class="repo-topics">
        {repo.topics.slice(0, 4).map((topic: string) => (
          <span class="repo-topic">{topic}</span>
        ))}
      </div>
    )}
  </div>

  <div class="repo-footer">
    <div class="repo-stats">
      {repo.language && (
        <span class="repo-language">
          <span class="language-dot" style={`background-color: ${langColor}`}></span>
          {repo.language}
        </span>
      )}
      {repo.stars > 0 && (
        <span class="repo-stat">
          <Star size={14} />
          {repo.stars}
        </span>
      )}
      {repo.forks > 0 && (
        <span class="repo-stat">
          <GitFork size={14} />
          {repo.forks}
        </span>
      )}
    </div>

    <div class="repo-links">
      {repo.homepage && (
        <a
          href={repo.homepage}
          target="_blank"
          rel="noopener noreferrer"
          class="repo-link repo-link-demo"
          title="Live Demo"
        >
          <ExternalLink size={16} />
        </a>
      )}
      <a
        href={repo.url}
        target="_blank"
        rel="noopener noreferrer"
        class="repo-link repo-link-github"
        title="View on GitHub"
      >
        <Github size={16} />
      </a>
    </div>
  </div>
</article>

<style>
  .github-repo-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid rgb(226 232 240 / 0.9);
    background: linear-gradient(135deg, rgb(255 255 255 / 0.9) 0%, rgb(248 250 252 / 0.8) 100%);
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.05);
    backdrop-filter: blur(8px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateY(20px);
    animation: repo-reveal 0.6s ease-out forwards;
    position: relative;
    overflow: hidden;
  }

  @keyframes repo-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .github-repo-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, rgb(13 148 136), rgb(45 212 191));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .github-repo-card:hover {
    transform: translateY(-4px);
    border-color: rgb(13 148 136 / 0.4);
    box-shadow: 0 12px 24px -4px rgb(13 148 136 / 0.15);
  }

  .github-repo-card:hover::before {
    transform: scaleX(1);
  }

  .dark .github-repo-card {
    border-color: rgb(51 65 85 / 0.8);
    background: linear-gradient(135deg, rgb(15 23 42 / 0.9) 0%, rgb(30 41 59 / 0.8) 100%);
  }

  .dark .github-repo-card:hover {
    border-color: rgb(45 212 191 / 0.4);
    box-shadow: 0 12px 24px -4px rgb(45 212 191 / 0.15);
  }

  .repo-header {
    flex: 1;
  }

  .repo-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: rgb(15 23 42);
    margin-bottom: 0.5rem;
  }

  .dark .repo-title {
    color: rgb(248 250 252);
  }

  .repo-description {
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgb(71 85 105);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .dark .repo-description {
    color: rgb(148 163 184);
  }

  .repo-body {
    min-height: 2rem;
  }

  .repo-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .repo-topic {
    font-size: 0.75rem;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    background-color: rgb(240 253 250);
    color: rgb(17 94 89);
    border: 1px solid rgb(20 184 166 / 0.2);
  }

  .dark .repo-topic {
    background-color: rgb(19 78 74 / 0.3);
    color: rgb(153 246 228);
    border-color: rgb(45 212 191 / 0.2);
  }

  .repo-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgb(226 232 240 / 0.5);
  }

  .dark .repo-footer {
    border-top-color: rgb(51 65 85 / 0.5);
  }

  .repo-stats {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.75rem;
    color: rgb(100 116 139);
  }

  .dark .repo-stats {
    color: rgb(148 163 184);
  }

  .repo-language {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .language-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
  }

  .repo-stat {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .repo-links {
    display: flex;
    gap: 0.5rem;
  }

  .repo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    transition: all 0.2s;
  }

  .repo-link-demo {
    background-color: rgb(13 148 136);
    color: white;
  }

  .repo-link-demo:hover {
    background-color: rgb(15 118 110);
    transform: scale(1.1);
  }

  .repo-link-github {
    border: 1px solid rgb(203 213 225);
    background-color: white;
    color: rgb(51 65 85);
  }

  .repo-link-github:hover {
    border-color: rgb(13 148 136);
    background-color: rgb(240 253 250);
    color: rgb(13 148 136);
    transform: scale(1.1);
  }

  .dark .repo-link-demo {
    background-color: rgb(20 184 166);
    color: rgb(15 23 42);
  }

  .dark .repo-link-demo:hover {
    background-color: rgb(45 212 191);
  }

  .dark .repo-link-github {
    border-color: rgb(71 85 105);
    background-color: rgb(30 41 59);
    color: rgb(203 213 225);
  }

  .dark .repo-link-github:hover {
    border-color: rgb(45 212 191);
    background-color: rgb(19 78 74);
    color: rgb(45 212 191);
  }
</style>
