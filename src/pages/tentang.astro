---
import Layout from '../layouts/Layout.astro';
import { aboutContent, aboutMeta } from '../config/pages/about';
---

<Layout title={aboutMeta.title} description={aboutMeta.description} socialImage={aboutMeta.socialImage} active="about">
  <main id="main" class="mx-auto max-w-5xl px-4 py-14 sm:px-6 sm:py-20">
    <header class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-teal-700 dark:text-teal-400">
        Perkenalan
      </p>
      <h1 class="font-display mt-3 text-4xl font-normal tracking-tight text-slate-900 sm:text-5xl dark:text-slate-50">
        {aboutContent.intro.title}
      </h1>
    </header>

    <div class="mt-12 grid gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:gap-16">
      <div class="space-y-6">
        {
          aboutContent.intro.paragraphs.map((p) => (
            <p class="text-lg leading-relaxed text-slate-600 dark:text-slate-400">{p}</p>
          ))
        }
      </div>
      <aside class="space-y-8 lg:pt-2">
        <div class="card-surface p-6">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-50">
            {aboutContent.principles.title}
          </h2>
          <ul class="mt-4 space-y-4" role="list">
            {
              aboutContent.principles.items.map((item) => (
                <li>
                  <p class="font-medium text-slate-800 dark:text-slate-100">{item.title}</p>
                  <p class="mt-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                    {item.text}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="card-surface p-6">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-50">
            {aboutContent.skills.title}
          </h2>
          <div class="mt-4 space-y-5">
            {
              aboutContent.skills.groups.map((g) => (
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-teal-700 dark:text-teal-400">
                    {g.label}
                  </p>
                  <ul class="mt-2 flex flex-wrap gap-2" role="list">
                    {g.items.map((skill) => (
                      <li>
                        <span class="inline-block rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200">
                          {skill}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </div>
      </aside>
    </div>
  </main>
</Layout>
