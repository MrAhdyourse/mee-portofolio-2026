---
import Layout from '../layouts/Layout.astro';
import { site } from '../config/site';
import { homeContent, homeMeta } from '../config/pages/home';
import { assetUrl, pageUrl } from '../lib/urls';

const ring =
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-950';

const profileSrc = assetUrl(site.profile.image);
const cvHref = assetUrl(site.cv.file);
---

<Layout title={homeMeta.title} description={homeMeta.description} socialImage={homeMeta.socialImage} active="home">
  <main id="main">
    <section
      class="relative mx-auto max-w-5xl overflow-hidden px-4 pb-16 pt-12 sm:px-6 sm:pb-24 sm:pt-16"
      aria-labelledby="hero-heading"
    >
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14">
        <div class="relative z-10">
          <p
            class="text-xs font-semibold uppercase tracking-[0.2em] text-teal-700 dark:text-teal-400"
          >
            {homeContent.hero.eyebrow}
          </p>
          <h1
            id="hero-heading"
            class="font-display mt-5 text-4xl font-normal leading-[1.12] tracking-tight text-slate-900 sm:text-5xl lg:text-[3.15rem] dark:text-slate-50"
          >
            {homeContent.hero.headlineBefore}
            <span class="text-teal-600 dark:text-teal-400">{homeContent.hero.headlineAccent}</span>{
              homeContent.hero.headlineAfter
            }
          </h1>
          <p
            class="mt-6 max-w-xl text-lg leading-relaxed text-slate-600 dark:text-slate-400"
          >
            {homeContent.hero.lead}
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a
              href={pageUrl(homeContent.hero.primaryCta.segment)}
              class={`inline-flex items-center justify-center rounded-xl bg-teal-600 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-teal-600/25 transition hover:bg-teal-700 dark:bg-teal-500 dark:text-slate-950 dark:hover:bg-teal-400 ${ring}`}
            >
              {homeContent.hero.primaryCta.label}
            </a>
            <a
              href={pageUrl(homeContent.hero.secondaryCta.segment)}
              class={`inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-800 transition hover:border-slate-400 hover:bg-white dark:border-slate-600 dark:bg-slate-900/80 dark:text-slate-100 dark:hover:border-slate-500 ${ring}`}
            >
              {homeContent.hero.secondaryCta.label}
            </a>
            <a
              href={cvHref}
              download
              class={`inline-flex items-center justify-center gap-2 rounded-xl border border-dashed border-teal-500/50 bg-teal-500/5 px-5 py-3 text-sm font-semibold text-teal-800 transition hover:border-teal-500 hover:bg-teal-500/10 dark:border-teal-400/40 dark:bg-teal-400/5 dark:text-teal-200 dark:hover:bg-teal-400/10 ${ring}`}
            >
              <span aria-hidden="true">⬇</span>
              {site.cv.label}
            </a>
          </div>
          <p class="mt-4 max-w-md text-xs text-slate-500 dark:text-slate-500">
            Letakkan PDF CV di <code class="rounded bg-slate-200/80 px-1 py-0.5 dark:bg-slate-800/80">public/cv/</code>
            dan sesuaikan path di <code class="rounded bg-slate-200/80 px-1 py-0.5 dark:bg-slate-800/80">src/config/site.ts</code> (lihat
            <code class="rounded bg-slate-200/80 px-1 py-0.5 dark:bg-slate-800/80">public/cv/BACA-INI.txt</code>).
          </p>
        </div>
        <div class="relative mx-auto w-full max-w-sm lg:mx-0 lg:max-w-none">
          <div
            class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-teal-400/30 via-transparent to-amber-300/20 blur-2xl dark:from-teal-500/20 dark:to-amber-500/10"
            aria-hidden="true"
          >
          </div>
          <figure
            class="card-surface relative overflow-hidden rounded-3xl p-2 shadow-xl shadow-slate-900/10 dark:shadow-black/40"
          >
            <img
              src={profileSrc}
              width={480}
              height={480}
              alt={site.profile.imageAlt}
              class="aspect-square w-full rounded-2xl object-cover"
              loading="eager"
            />
            <figcaption class="sr-only">{site.profile.imageAlt}</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section
      class="mx-auto max-w-5xl px-4 pb-20 sm:px-6 sm:pb-28"
      aria-labelledby="pillars-heading"
    >
      <h2 id="pillars-heading" class="sr-only">Ringkasan fokus</h2>
      <ul class="grid gap-5 sm:grid-cols-3" role="list">
        {
          homeContent.pillars.map((p) => (
            <li class="card-surface group p-6 transition hover:-translate-y-0.5 hover:border-teal-500/35">
              <span
                class="text-2xl text-teal-600 opacity-90 dark:text-teal-400"
                aria-hidden="true"
              >
                {p.icon}
              </span>
              <h3 class="mt-3 font-semibold text-slate-900 dark:text-slate-50">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{p.body}</p>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>
