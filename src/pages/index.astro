---
import Layout from '../layouts/Layout.astro';
import { site } from '../config/site';
import { homeContent, homeMeta } from '../config/pages/home';
import { assetUrl, pageUrl } from '../lib/urls';
import { Github, Linkedin, Mail, ChevronDown } from 'lucide-astro';

const ring =
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-950';

const profileSrc = assetUrl(site.profile.image);
const cvHref = assetUrl(site.cv.file);
const cvDownloadName = site.cv.file.split('/').pop() ?? 'cv.pdf';
---

<Layout title={homeMeta.title} description={homeMeta.description} socialImage={homeMeta.socialImage} active="home">
  <main id="main">
    <section
      class="relative mx-auto max-w-5xl overflow-hidden px-4 pb-16 pt-12 sm:px-6 sm:pb-24 sm:pt-16"
      aria-labelledby="hero-heading"
    >
      <!-- Animated gradient orbs -->
      <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
        <div class="hero-orb hero-orb-3"></div>
      </div>

      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14">
        <div class="relative z-10 hero-content">
          <p
            class="text-xs font-semibold uppercase tracking-[0.2em] text-teal-700 dark:text-teal-400"
          >
            {homeContent.hero.eyebrow}
          </p>
          <h1
            id="hero-heading"
            class="font-display mt-5 text-4xl font-normal leading-[1.12] tracking-tight text-slate-900 sm:text-5xl lg:text-[3.15rem] dark:text-slate-50"
          >
            {homeContent.hero.headlineBefore}
            <span class="typing-text text-teal-600 dark:text-teal-400">{homeContent.hero.headlineAccent}</span>{
              homeContent.hero.headlineAfter
            }
          </h1>
          <p
            class="mt-6 max-w-xl text-lg leading-relaxed text-slate-600 dark:text-slate-400"
          >
            {homeContent.hero.lead}
          </p>
          
          <!-- Social Links -->
          <div class="mt-8 flex items-center gap-4">
            <a
              href="https://github.com/MrAhdyourse"
              target="_blank"
              rel="noopener noreferrer"
              class={`social-icon ${ring}`}
              aria-label="GitHub Profile"
            >
              <Github size={20} />
            </a>
            <a
              href="https://id.linkedin.com/in/ahdi-aghni"
              target="_blank"
              rel="noopener noreferrer"
              class={`social-icon ${ring}`}
              aria-label="LinkedIn Profile"
            >
              <Linkedin size={20} />
            </a>
            <a
              href="mailto:ahdi.aghnii@gmail.com"
              class={`social-icon ${ring}`}
              aria-label="Email Contact"
            >
              <Mail size={20} />
            </a>
          </div>

          <div class="mt-10 flex flex-wrap items-center gap-3">
            <a
              href={pageUrl(homeContent.hero.primaryCta.segment)}
              class={`cta-button cta-primary ${ring}`}
            >
              {homeContent.hero.primaryCta.label}
            </a>
            <a
              href={pageUrl(homeContent.hero.secondaryCta.segment)}
              class={`cta-button cta-secondary ${ring}`}
            >
              {homeContent.hero.secondaryCta.label}
            </a>
            <a
              href={cvHref}
              download={cvDownloadName}
              class={`cta-button cta-download ${ring}`}
            >
              <span aria-hidden="true">⬇</span>
              {site.cv.label}
            </a>
          </div>
        </div>

        <div class="relative mx-auto w-full max-w-md lg:mx-0 lg:max-w-none hero-image">
          <!-- Professional Profile Card -->
          <div class="profile-card-wrapper">
            <div class="profile-card">
              <div class="profile-image-container">
                <img
                  src={profileSrc}
                  alt={site.profile.imageAlt}
                  class="profile-photo"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                />
                <div class="profile-status">
                  <span class="status-dot"></span>
                  <span class="status-text">Available for work</span>
                </div>
              </div>
              
              <!-- Stats Grid -->
              <div class="stats-grid">
                <div class="stat-card">
                  <div class="stat-icon">💼</div>
                  <div class="stat-value">5+</div>
                  <div class="stat-label">Years Experience</div>
                </div>
                <div class="stat-card">
                  <div class="stat-icon">🚀</div>
                  <div class="stat-value">20+</div>
                  <div class="stat-label">Projects Done</div>
                </div>
                <div class="stat-card">
                  <div class="stat-icon">⚡</div>
                  <div class="stat-value">15+</div>
                  <div class="stat-label">Tech Stack</div>
                </div>
                <div class="stat-card">
                  <div class="stat-icon">🎯</div>
                  <div class="stat-value">100%</div>
                  <div class="stat-label">Client Satisfaction</div>
                </div>
              </div>

              <!-- Quick Actions -->
              <div class="quick-actions">
                <a
                  href={cvHref}
                  download={cvDownloadName}
                  class="quick-action-btn quick-action-primary"
                >
                  <span>📄</span>
                  <span>Download CV</span>
                </a>
                <a
                  href={pageUrl('kontak')}
                  class="quick-action-btn quick-action-secondary"
                >
                  <span>💬</span>
                  <span>Contact Me</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="scroll-indicator">
        <ChevronDown size={24} class="animate-bounce" />
      </div>
    </section>

    <!-- Tech Stack Section -->
    <section
      class="mx-auto max-w-5xl px-4 pb-16 sm:px-6 sm:pb-20"
      aria-labelledby="tech-stack-heading"
    >
      <div class="text-center">
        <h2 id="tech-stack-heading" class="text-2xl font-semibold text-slate-900 dark:text-slate-50">
          Tech Stack & Tools
        </h2>
        <p class="mt-2 text-slate-600 dark:text-slate-400">
          Teknologi dan tools yang saya gunakan sehari-hari
        </p>
      </div>
      
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <div class="tech-category">
          <h3 class="tech-category-title">Frontend</h3>
          <div class="tech-grid">
            <div class="tech-item">
              <span class="tech-icon">⚛️</span>
              <span class="tech-name">React</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">🎨</span>
              <span class="tech-name">Tailwind</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">🚀</span>
              <span class="tech-name">Astro</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">📘</span>
              <span class="tech-name">TypeScript</span>
            </div>
          </div>
        </div>

        <div class="tech-category">
          <h3 class="tech-category-title">Backend</h3>
          <div class="tech-grid">
            <div class="tech-item">
              <span class="tech-icon">🟢</span>
              <span class="tech-name">Node.js</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">🐍</span>
              <span class="tech-name">Python</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">🐘</span>
              <span class="tech-name">PHP</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">🗄️</span>
              <span class="tech-name">MySQL</span>
            </div>
          </div>
        </div>

        <div class="tech-category">
          <h3 class="tech-category-title">Infrastructure</h3>
          <div class="tech-grid">
            <div class="tech-item">
              <span class="tech-icon">🐧</span>
              <span class="tech-name">Linux</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">🐳</span>
              <span class="tech-name">Docker</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">🌐</span>
              <span class="tech-name">Nginx</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">☁️</span>
              <span class="tech-name">Cloud</span>
            </div>
          </div>
        </div>

        <div class="tech-category">
          <h3 class="tech-category-title">Tools</h3>
          <div class="tech-grid">
            <div class="tech-item">
              <span class="tech-icon">📦</span>
              <span class="tech-name">Git</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">💻</span>
              <span class="tech-name">VS Code</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">🔧</span>
              <span class="tech-name">Postman</span>
            </div>
            <div class="tech-item">
              <span class="tech-icon">📊</span>
              <span class="tech-name">Analytics</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Pillars Section -->
    <section
      class="mx-auto max-w-5xl px-4 pb-20 sm:px-6 sm:pb-28"
      aria-labelledby="pillars-heading"
    >
      <h2 id="pillars-heading" class="sr-only">Ringkasan keahlian</h2>
      <ul class="grid gap-5 sm:grid-cols-3" role="list">
        {
          homeContent.pillars.map((p, i) => (
            <li class="pillar-card" style={`animation-delay: ${i * 0.1}s`}>
              <div class="pillar-icon-wrapper">
                <span class="pillar-icon" aria-hidden="true">
                  {p.icon}
                </span>
              </div>
              <h3 class="pillar-title">{p.title}</h3>
              <p class="pillar-body">{p.body}</p>
              <div class="pillar-shine" aria-hidden="true"></div>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>

<script>
  // Scroll reveal animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('reveal-visible');
      }
    });
  }, observerOptions);

  // Observe all sections and cards
  document.querySelectorAll('section, .tech-category, .pillar-card').forEach(el => {
    el.classList.add('reveal');
    observer.observe(el);
  });

  // Parallax effect for hero orbs
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        const scrolled = window.scrollY;
        const orbs = document.querySelectorAll('.hero-orb');
        orbs.forEach((orb, i) => {
          const speed = 0.3 + (i * 0.1);
          (orb as HTMLElement).style.transform = `translateY(${scrolled * speed}px)`;
        });
        ticking = false;
      });
      ticking = true;
    }
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      const href = this.getAttribute('href');
      if (href && href !== '#') {
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
</script>
