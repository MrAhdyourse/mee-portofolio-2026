---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projectsPageContent, projectsMeta } from '../config/pages/projects';
import { allProjectTags, projects } from '../data/projects';

const ring =
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-950';
---

<Layout
  title={projectsMeta.title}
  description={projectsMeta.description}
  socialImage={projectsMeta.socialImage}
  active="projects"
>
  <main id="main" class="mx-auto max-w-5xl px-4 py-14 sm:px-6 sm:py-20">
    <header class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-teal-700 dark:text-teal-400">
        {projectsPageContent.section.eyebrow}
      </p>
      <h1 class="font-display mt-3 text-4xl font-normal tracking-tight text-slate-900 sm:text-5xl dark:text-slate-50">
        {projectsPageContent.section.title}
      </h1>
      <p class="mt-4 max-w-xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
        {projectsPageContent.section.lead}
      </p>
    </header>

    <div
      class="mt-10 flex flex-wrap gap-2"
      role="toolbar"
      aria-label="Filter proyek berdasarkan tag"
    >
      <button
        type="button"
        data-filter="all"
        class={`filter-btn rounded-full border border-teal-600 bg-teal-600 px-4 py-2 text-sm font-medium text-white dark:border-teal-500 dark:bg-teal-500 dark:text-slate-950 ${ring}`}
        aria-controls="project-grid"
      >
        Semua
      </button>
      {
        allProjectTags.map((tag) => (
          <button
            type="button"
            data-filter={tag.toLowerCase().replace(/\s+/g, '-')}
            class={`filter-btn rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-teal-500/50 hover:text-teal-800 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-teal-500/40 dark:hover:text-teal-300 ${ring}`}
            aria-controls="project-grid"
          >
            {tag}
          </button>
        ))
      }
    </div>
    <p id="filter-status" class="sr-only" aria-live="polite" />
    <div
      class="mt-10 grid gap-6 sm:grid-cols-2"
      id="project-grid"
      role="list"
    >
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <p
      class="mt-6 text-sm text-slate-500 dark:text-slate-500"
      id="project-empty"
      role="status"
      aria-live="polite"
      hidden
    >
      {projectsPageContent.emptyFilterMessage}
    </p>
  </main>

  <script define:vars={{ emptyMsg: projectsPageContent.emptyFilterMessage }}>
    const activeBtn = [
      'border-teal-600',
      'bg-teal-600',
      'text-white',
      'shadow-sm',
      'shadow-teal-600/20',
      'dark:border-teal-500',
      'dark:bg-teal-500',
      'dark:text-slate-950',
    ];
    const idleBtn = [
      'border-slate-300',
      'bg-white',
      'text-slate-700',
      'hover:border-teal-500/50',
      'hover:text-teal-800',
      'dark:border-slate-600',
      'dark:bg-slate-900',
      'dark:text-slate-200',
      'dark:hover:border-teal-500/40',
      'dark:hover:text-teal-300',
    ];

    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.project-card');
    const emptyEl = document.getElementById('project-empty');
    const filterStatus = document.getElementById('filter-status');

    function paintButtons(chosen: HTMLButtonElement) {
      buttons.forEach((b) => {
        const on = b === chosen;
        activeBtn.forEach((c) => b.classList.toggle(c, on));
        idleBtn.forEach((c) => b.classList.toggle(c, !on));
      });
    }

    function applyFilter(slug: string | undefined) {
      let visible = 0;
      const all = slug === 'all' || !slug;
      cards.forEach((card) => {
        const tags = (card as HTMLElement).dataset.tags ?? '';
        const show = all || tags.split(/\s+/).some((t) => t === slug);
        card.classList.toggle('hidden', !show);
        if (show) visible += 1;
      });
      if (emptyEl) {
        emptyEl.textContent = emptyMsg;
        emptyEl.hidden = visible !== 0;
      }
      if (filterStatus) {
        if (visible === 0) filterStatus.textContent = '';
        else if (all) filterStatus.textContent = `Menampilkan ${visible} proyek.`;
        else filterStatus.textContent = `Filter aktif. Menampilkan ${visible} proyek.`;
      }
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        paintButtons(btn as HTMLButtonElement);
        applyFilter((btn as HTMLButtonElement).dataset.filter);
      });
    });

    const defaultBtn =
      document.querySelector<HTMLButtonElement>('[data-filter="all"]') ?? null;
    if (defaultBtn) paintButtons(defaultBtn);
    applyFilter('all');
  </script>
</Layout>
