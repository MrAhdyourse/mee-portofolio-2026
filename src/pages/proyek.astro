---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import GitHubRepoCard from '../components/GitHubRepoCard.astro';
import { projectsPageContent, projectsMeta } from '../config/pages/projects';
import { projects } from '../data/projects';

const ring =
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-950';

// Fetch GitHub repos
const GITHUB_USERNAME = 'MrAhdyourse';
let githubRepos = [];

try {
  const response = await fetch(`https://api.github.com/users/${GITHUB_USERNAME}/repos?sort=updated&per_page=12`);
  if (response.ok) {
    const repos = await response.json();
    githubRepos = repos
      .filter((repo: any) => !repo.fork && !repo.private)
      .map((repo: any) => ({
        name: repo.name,
        description: repo.description || 'No description available',
        url: repo.html_url,
        homepage: repo.homepage,
        stars: repo.stargazers_count,
        forks: repo.forks_count,
        language: repo.language,
        topics: repo.topics || [],
        updated: repo.updated_at,
      }));
  }
} catch (error) {
  console.error('Failed to fetch GitHub repos:', error);
}
---

<Layout
  title={projectsMeta.title}
  description={projectsMeta.description}
  socialImage={projectsMeta.socialImage}
  active="projects"
>
  <main id="main" class="mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-20">
    <header class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-teal-700 dark:text-teal-400">
        {projectsPageContent.section.eyebrow}
      </p>
      <h1 class="font-display mt-3 text-4xl font-normal tracking-tight text-slate-900 sm:text-5xl dark:text-slate-50">
        {projectsPageContent.section.title}
      </h1>
      <p class="mt-4 max-w-xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
        {projectsPageContent.section.lead}
      </p>
    </header>

    <!-- Featured Projects -->
    <section class="mt-12">
      <h2 class="mb-6 text-xl font-semibold text-slate-900 dark:text-slate-50">
        ⭐ Featured Projects
      </h2>
      <div class="grid gap-6 sm:grid-cols-2" role="list">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <!-- GitHub Repositories -->
    {githubRepos.length > 0 && (
      <section class="mt-16">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-50">
            🚀 GitHub Repositories
          </h2>
          <a
            href={`https://github.com/${GITHUB_USERNAME}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-teal-600 hover:text-teal-700 dark:text-teal-400 dark:hover:text-teal-300"
          >
            View All on GitHub →
          </a>
        </div>
        
        <!-- Bento Grid Layout -->
        <div class="bento-grid">
          {githubRepos.map((repo: any, i: number) => (
            <GitHubRepoCard repo={repo} index={i} />
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    grid-auto-flow: dense;
  }

  @media (min-width: 640px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    
    /* Make some cards span 2 columns for visual interest */
    .bento-grid > :nth-child(4n + 1) {
      grid-column: span 2;
    }
  }
</style>
