---
import Layout from '../layouts/Layout.astro';
import { pageUrl } from '../lib/urls';

const ring =
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-950';
---

<Layout
  title="Halaman tidak ditemukan | Portofolio"
  description="Tautan mungkin rusak atau halaman sudah dipindahkan."
  active="home"
>
  <main id="main" class="mx-auto max-w-lg px-4 py-24 text-center sm:px-6 sm:py-32">
    <div class="error-animation">
      <span class="error-number">4</span>
      <span class="error-icon">🔍</span>
      <span class="error-number">4</span>
    </div>
    <h1 class="mt-8 font-display text-2xl text-slate-900 dark:text-slate-50">
      Halaman tidak ditemukan
    </h1>
    <p class="mt-3 text-slate-600 dark:text-slate-400">
      Periksa URL atau kembali ke beranda.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href={pageUrl('')} class="cta-button cta-primary">
        ← Ke beranda
      </a>
      <a href={pageUrl('proyek')} class="cta-button cta-secondary">
        Lihat Proyek
      </a>
    </div>
  </main>
</Layout>

<style>
  .error-animation {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    font-size: 4rem;
  }

  .error-number {
    font-weight: 700;
    background: linear-gradient(135deg, rgb(13 148 136), rgb(45 212 191));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: pulse 2s ease-in-out infinite;
  }

  .error-icon {
    font-size: 3rem;
    animation: bounce 1s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
</style>
