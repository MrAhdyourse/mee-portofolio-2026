---
import Layout from '../layouts/Layout.astro';
import { Mail, Github, Linkedin, Send } from 'lucide-astro';
import {
  contactContent,
  contactMeta,
  type ContactLink,
} from '../config/pages/contact';

const ring =
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-slate-950';

function linkClass(link: ContactLink): string {
  const base = `inline-flex items-center justify-center gap-2 rounded-xl px-5 py-3 text-sm font-semibold transition-all duration-300 ${ring}`;
  if (link.variant === 'primary')
    return `${base} bg-teal-600 text-white hover:scale-105 hover:bg-teal-700 hover:shadow-lg hover:shadow-teal-600/30 dark:bg-teal-500 dark:text-slate-950 dark:hover:bg-teal-400`;
  if (link.variant === 'secondary')
    return `${base} border border-slate-300 bg-white text-slate-800 hover:scale-105 hover:border-slate-400 hover:shadow-md dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100 dark:hover:border-slate-500`;
  return `${base} border border-transparent text-teal-700 underline-offset-4 hover:underline dark:text-teal-300`;
}

const iconMap: Record<string, any> = {
  'email': Mail,
  'github': Github,
  'linkedin': Linkedin,
};
---

<Layout title={contactMeta.title} description={contactMeta.description} socialImage={contactMeta.socialImage} active="contact">
  <main id="main" class="mx-auto max-w-5xl px-4 py-14 sm:px-6 sm:py-20">
    <header class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-teal-700 dark:text-teal-400">
        Kolaborasi
      </p>
      <h1 class="font-display mt-3 text-4xl font-normal tracking-tight text-slate-900 sm:text-5xl dark:text-slate-50">
        {contactContent.section.title}
      </h1>
      <p class="mt-4 max-w-xl text-lg leading-relaxed text-slate-600 dark:text-slate-400">
        {contactContent.section.lead}
      </p>
    </header>

    <div class="mt-12 grid gap-8 lg:grid-cols-2">
      <!-- Contact Links -->
      <div class="space-y-4">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-50">Hubungi Saya</h2>
        <div class="space-y-3">
          {
            contactContent.links.map((link) => {
              const Icon = iconMap[link.label.toLowerCase()] || Mail;
              return (
                <a
                  class="contact-method-card"
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >
                  <div class="contact-icon">
                    <Icon size={20} />
                  </div>
                  <div class="flex-1">
                    <p class="font-medium text-slate-900 dark:text-slate-50">{link.label}</p>
                    <p class="text-sm text-slate-600 dark:text-slate-400">
                      {link.href.replace('mailto:', '').replace('https://', '')}
                    </p>
                  </div>
                  <Send size={16} class="contact-arrow" />
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- Quick Contact Form -->
      <div class="contact-form-card">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-50">Kirim Pesan Cepat</h2>
        <form class="mt-6 space-y-4" id="contact-form">
          <div>
            <label for="name" class="contact-label">Nama</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="contact-input"
              placeholder="Nama Anda"
            />
          </div>
          <div>
            <label for="email" class="contact-label">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="contact-input"
              placeholder="email@example.com"
            />
          </div>
          <div>
            <label for="message" class="contact-label">Pesan</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="contact-input"
              placeholder="Tulis pesan Anda..."
            ></textarea>
          </div>
          <button type="submit" class="contact-submit">
            <Send size={16} />
            <span>Kirim Pesan</span>
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const name = formData.get('name');
    const email = formData.get('email');
    const message = formData.get('message');
    
    // Create mailto link
    const subject = encodeURIComponent(`Pesan dari ${name}`);
    const body = encodeURIComponent(`Nama: ${name}\nEmail: ${email}\n\nPesan:\n${message}`);
    window.location.href = `mailto:ahdi.aghnii@gmail.com?subject=${subject}&body=${body}`;
    
    // Reset form
    form.reset();
  });
</script>
